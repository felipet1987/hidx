# hidx environment variables
# Copy to .env.local and fill in values for your environment.

# --- Supabase ---
# Local: from `supabase start` output (use sb_publishable_*, sb_secret_*)
# Cloud: from project settings > API
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<sb_publishable_xxx>
SUPABASE_SERVICE_ROLE=<sb_secret_xxx>

# Toggle Supabase loader (false = legacy glob loader fallback)
USE_SUPABASE_LOADER=true

# --- Cloudflare ---
# Pages Deploy Hook URL (set as Supabase Edge Function secret in prod)
CF_DEPLOY_HOOK_URL=

# --- Beehiiv (newsletter) ---
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
