---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
  featured: CollectionEntry<'posts'>[];
}

const { featured } = Astro.props;

const pillarTopics = [
  'edge functions',
  'observabilidad',
  'desarrollo asistido por ia',
  'internals de bases de datos',
  'prompt engineering',
  'cloudflare workers',
  'tdd a escala',
  'ergonomía de monorepos',
  'astro islands',
  'diseño de sistemas',
];
---
<BaseLayout
  title="hidx — Cómo lo hago"
  description="Guías largas y opinadas sobre cómo resuelvo problemas reales con código, infraestructura y herramientas."
>
  <section class="hero">
    <div class="hero-mesh" aria-hidden="true"></div>
    <div class="hero-inner">
      <p class="eyebrow">cómo lo hago</p>
      <h1>
        Guías largas<br />
        para <span class="text-gradient">quienes les importa</span>.
      </h1>
      <p class="lede">
        Walkthroughs opinados, reproducibles y de punta a punta sobre código, infraestructura y herramientas.
      </p>
      <a href="/posts" class="cta">Leer los artículos →</a>

      <div class="marquee" aria-hidden="true">
        <div class="marquee-track">
          {pillarTopics.concat(pillarTopics).map((t) => (
            <span class="topic">#{t}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="featured">
      <h2>Recientes</h2>
      <ul class="featured-list">
        {featured.map((p) => (
          <li>
            <a href={`/posts/${p.id}`} class="card">
              <span class="card-glow" aria-hidden="true"></span>
              <h3>{p.data.title}</h3>
              <p>{p.data.description}</p>
              <time datetime={p.data.publishedAt.toISOString()}>
                {p.data.publishedAt.toLocaleDateString('es', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="newsletter">
    <h2>Suscríbete</h2>
    <p>Nuevas publicaciones directo a tu correo. Sin spam.</p>
    <p class="placeholder">[Formulario de newsletter llega en S4]</p>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    padding: 5rem 0 3rem;
    overflow: hidden;
  }
  .hero-mesh {
    position: absolute;
    inset: -10%;
    z-index: -1;
    background-image: var(--gradient-mesh);
    filter: blur(40px);
    opacity: 0.95;
  }
  .hero-inner {
    text-align: center;
    display: grid;
    gap: 1.25rem;
    place-items: center;
  }
  .eyebrow {
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-transform: lowercase;
    letter-spacing: 0.18em;
    font-size: 0.85rem;
    margin: 0;
  }
  .hero h1 {
    font-size: var(--text-5xl);
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 22ch;
  }
  .hero .lede {
    color: var(--color-muted);
    font-size: var(--text-lg);
    max-width: 36ch;
    margin: 0;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.4rem;
    margin-top: 0.5rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2));
    color: white;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px color-mix(in oklch, var(--color-accent-2) 35%, transparent);
    color: white;
  }

  .marquee {
    width: 100%;
    overflow: hidden;
    margin-top: 2rem;
    mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 12%, black 88%, transparent);
  }
  .marquee-track {
    display: inline-flex;
    gap: 1.5rem;
    white-space: nowrap;
    animation: marquee 40s linear infinite;
    will-change: transform;
  }
  .topic {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-muted);
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    background: var(--color-bg-elev);
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }

  .featured,
  .newsletter {
    padding: 3.5rem 0;
  }
  .featured h2,
  .newsletter h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin: 0 0 1.25rem;
    letter-spacing: -0.01em;
  }
  .featured-list {
    list-style: none;
    display: grid;
    gap: 0.85rem;
    margin: 0;
    padding: 0;
  }
  .card {
    position: relative;
    display: block;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-bg-elev);
    text-decoration: none;
    color: var(--color-fg);
    transition: transform 0.18s ease, border-color 0.18s ease;
    overflow: hidden;
  }
  .card-glow {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2));
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: transparent;
  }
  .card:hover .card-glow {
    opacity: 1;
  }
  .card h3 {
    font-size: var(--text-lg);
    font-weight: 700;
    margin: 0 0 0.35rem;
  }
  .card p {
    color: var(--color-muted);
    font-size: 0.95rem;
    margin: 0 0 0.5rem;
  }
  .card time {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .newsletter {
    text-align: center;
    border-top: 1px solid var(--color-border);
  }
  .newsletter p {
    color: var(--color-muted);
    margin: 0 0 0.5rem;
  }
  .newsletter .placeholder {
    font-size: 0.85rem;
    opacity: 0.6;
  }
</style>
