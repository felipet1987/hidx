---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  headings: { depth: number; slug: string; text: string }[];
  readingMinutes: number;
}

const { post, headings, readingMinutes } = Astro.props;
const { title, description, publishedAt, updatedAt, tags, cover } = post.data;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  author: { '@type': 'Person', name: 'Felipe Talavera' },
  image: cover ?? `https://hidx.dev/og/${post.id}.png`,
};
---
<BaseLayout title={title} description={description} type="article" ogImage={`https://hidx.dev/og/${post.id}.png`}>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
    slot="head"
  />

  <article class="prose prose-invert max-w-none">
    <header class="not-prose mb-8 space-y-3">
      <h1 class="text-4xl font-bold tracking-tight">{title}</h1>
      <p class="text-lg text-(--color-muted)">{description}</p>
      <div class="text-sm text-(--color-muted) flex flex-wrap gap-3">
        <time datetime={publishedAt.toISOString()}>
          {publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>·</span>
        <span>{readingMinutes} min read</span>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <ul class="flex gap-2">
              {tags.map((t) => (
                <li><a href={`/tags/${t}`} class="no-underline">#{t}</a></li>
              ))}
            </ul>
          </>
        )}
      </div>
    </header>

    {tocHeadings.length > 2 && (
      <nav class="not-prose mb-10 p-4 border border-(--color-accent-soft) rounded text-sm">
        <p class="font-semibold mb-2">On this page</p>
        <ul class="space-y-1">
          {tocHeadings.map((h) => (
            <li class={h.depth === 3 ? 'pl-4' : ''}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}

    <slot />

    <footer class="not-prose mt-16 pt-6 border-t border-(--color-accent-soft) text-sm text-(--color-muted)">
      <p>
        Some links may be affiliate links. If you click and buy, this site may earn a commission at no extra cost to you.
        See <a href="/disclosure">disclosure</a>.
      </p>
    </footer>
  </article>
</BaseLayout>
