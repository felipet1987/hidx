---
interface Props {
  size?: number;
  ariaLabel?: string;
  class?: string;
}

const { size = 32, ariaLabel = 'YachayTree', class: className } = Astro.props;
const id = `yt-${Math.random().toString(36).slice(2, 8)}`;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 32 32"
  width={size}
  height={size}
  role="img"
  aria-label={ariaLabel}
  class:list={['yt-logo', className]}
>
  <defs>
    <linearGradient id={id} x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="oklch(0.7 0.18 145)" />
      <stop offset="1" stop-color="oklch(0.72 0.18 50)" />
    </linearGradient>
  </defs>
  <rect x="1" y="1" width="30" height="30" rx="7" fill={`url(#${id})`} />
  <rect x="14.5" y="20" width="3" height="6" fill="white" opacity="0.95" />
  <circle cx="16" cy="11" r="4.5" fill="white" opacity="0.95" />
  <circle cx="11" cy="15" r="3.5" fill="white" opacity="0.85" />
  <circle cx="21" cy="15" r="3.5" fill="white" opacity="0.85" />
  <path
    d="M16 14 V19 M14 12 L16 14 L18 12"
    stroke="oklch(0.7 0.18 145)"
    stroke-width="1.2"
    stroke-linecap="round"
    fill="none"
  />
</svg>

<style>
  .yt-logo {
    display: inline-block;
    transition: transform 0.25s ease, filter 0.25s ease;
  }
  .yt-logo:hover {
    transform: rotate(-3deg) scale(1.04);
    filter: drop-shadow(0 4px 14px oklch(0.72 0.18 50 / 0.45));
  }
  @media (prefers-reduced-motion: reduce) {
    .yt-logo,
    .yt-logo:hover {
      transition: none;
      transform: none;
    }
  }
</style>
