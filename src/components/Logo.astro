---
interface Props {
  size?: number;
  ariaLabel?: string;
  class?: string;
}

const { size = 32, ariaLabel = 'hidx', class: className } = Astro.props;
const id = `lg-${Math.random().toString(36).slice(2, 8)}`;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 32 32"
  width={size}
  height={size}
  role="img"
  aria-label={ariaLabel}
  class:list={['hidx-logo', className]}
>
  <defs>
    <linearGradient id={id} x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="oklch(0.78 0.14 200)" />
      <stop offset="1" stop-color="oklch(0.72 0.18 295)" />
    </linearGradient>
  </defs>
  <rect x="1" y="1" width="30" height="30" rx="7" fill={`url(#${id})`} />
  <path
    d="M10 8 V24 M10 16 H22 M22 13 V24"
    stroke="white"
    stroke-width="2.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"
  />
</svg>

<style>
  .hidx-logo {
    display: inline-block;
    transition: transform 0.25s ease, filter 0.25s ease;
  }
  .hidx-logo:hover {
    transform: rotate(-3deg) scale(1.04);
    filter: drop-shadow(0 4px 14px oklch(0.62 0.21 295 / 0.45));
  }
  @media (prefers-reduced-motion: reduce) {
    .hidx-logo,
    .hidx-logo:hover {
      transition: none;
      transform: none;
    }
  }
</style>
