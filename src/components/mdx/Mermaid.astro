---
interface Props {
  code: string;
  caption?: string;
}

const { code, caption } = Astro.props;
const id = `mmd-${Math.random().toString(36).slice(2, 9)}`;
---
<figure class="mermaid-figure not-prose">
  <mermaid-block class="mermaid-block" data-mmd-id={id}>
    <pre class="mermaid-source" hidden>{code}</pre>
    <div class="mermaid-render" data-mmd-render>
      <div class="mermaid-skeleton" aria-busy="true">
        <span>Cargando diagrama…</span>
      </div>
    </div>
  </mermaid-block>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<script>
  type MermaidApi = {
    initialize: (cfg: Record<string, unknown>) => void;
    render: (id: string, src: string) => Promise<{ svg: string }>;
  };

  let mermaidPromise: Promise<MermaidApi> | null = null;

  function loadMermaid(): Promise<MermaidApi> {
    if (!mermaidPromise) {
      mermaidPromise = import('mermaid').then((m) => {
        const api = m.default as unknown as MermaidApi;
        const isDark = document.documentElement.dataset.theme === 'dark';
        api.initialize({
          startOnLoad: false,
          theme: isDark ? 'dark' : 'neutral',
          themeVariables: {
            primaryColor: isDark ? '#1f2937' : '#ffffff',
            primaryTextColor: isDark ? '#f9fafb' : '#0d2240',
            primaryBorderColor: isDark ? '#3b82f6' : '#0d2240',
            lineColor: isDark ? '#9ca3af' : '#6b7280',
            fontFamily: 'JetBrains Mono Variable, ui-monospace, monospace',
          },
          securityLevel: 'strict',
        });
        return api;
      });
    }
    return mermaidPromise;
  }

  class MermaidBlock extends HTMLElement {
    private observer: IntersectionObserver | null = null;
    private rendered = false;

    connectedCallback() {
      this.observer = new IntersectionObserver(
        (entries) => {
          if (entries[0]?.isIntersecting && !this.rendered) {
            this.render();
          }
        },
        { rootMargin: '200px' },
      );
      this.observer.observe(this);
    }

    disconnectedCallback() {
      this.observer?.disconnect();
    }

    private async render() {
      this.rendered = true;
      const src = this.querySelector<HTMLElement>('.mermaid-source')?.textContent?.trim();
      const target = this.querySelector<HTMLElement>('[data-mmd-render]');
      if (!src || !target) return;
      try {
        const api = await loadMermaid();
        const id = this.dataset.mmdId ?? `m${Date.now()}`;
        const { svg } = await api.render(id, src);
        target.innerHTML = svg;
      } catch (e) {
        target.innerHTML = `<pre class="mermaid-error">Error renderizando diagrama:\n${(e as Error).message}</pre>`;
      }
    }
  }
  if (!customElements.get('mermaid-block')) {
    customElements.define('mermaid-block', MermaidBlock);
  }
</script>

<style>
  .mermaid-figure {
    margin: 1.5rem 0;
  }
  .mermaid-block {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-elev);
    padding: 1rem;
    overflow-x: auto;
  }
  .mermaid-render {
    min-height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .mermaid-render :global(svg) {
    max-width: 100%;
    height: auto;
  }
  .mermaid-skeleton {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .mermaid-error {
    color: oklch(0.65 0.18 25);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    white-space: pre-wrap;
  }
  figcaption {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
    font-style: italic;
  }
</style>
