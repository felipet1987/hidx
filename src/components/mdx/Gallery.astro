---
interface Item {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  items: Item[];
  cols?: 2 | 3 | 4;
}

const { items, cols = 3 } = Astro.props;
---
<div class="gallery" data-gallery data-cols={cols}>
  {items.map((item, i) => (
    <button
      type="button"
      class="gallery-item"
      data-gallery-open
      data-index={i}
      aria-label={`Abrir imagen ${i + 1}: ${item.alt}`}
    >
      <img src={item.src} alt={item.alt} loading="lazy" decoding="async" />
    </button>
  ))}
</div>

<dialog class="gallery-lightbox" data-gallery-lightbox>
  <button type="button" class="lightbox-close" data-lightbox-close aria-label="Cerrar">×</button>
  <button type="button" class="lightbox-prev" data-lightbox-prev aria-label="Anterior">‹</button>
  <button type="button" class="lightbox-next" data-lightbox-next aria-label="Siguiente">›</button>
  <figure>
    <img data-lightbox-img alt="" />
    <figcaption data-lightbox-caption></figcaption>
  </figure>
</dialog>

<script define:vars={{ items }}>
  const lb = document.querySelector('[data-gallery-lightbox]');
  if (lb) {
    const img = lb.querySelector('[data-lightbox-img]');
    const cap = lb.querySelector('[data-lightbox-caption]');
    let current = 0;

    const show = (i) => {
      current = (i + items.length) % items.length;
      img.src = items[current].src;
      img.alt = items[current].alt;
      cap.textContent = items[current].caption ?? items[current].alt;
    };

    document.querySelectorAll('[data-gallery-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        show(Number(btn.dataset.index));
        lb.showModal();
      });
    });
    lb.querySelector('[data-lightbox-close]').addEventListener('click', () => lb.close());
    lb.querySelector('[data-lightbox-prev]').addEventListener('click', () => show(current - 1));
    lb.querySelector('[data-lightbox-next]').addEventListener('click', () => show(current + 1));
    lb.addEventListener('click', (e) => {
      if (e.target === lb) lb.close();
    });
    document.addEventListener('keydown', (e) => {
      if (!lb.open) return;
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  }
</script>

<style>
  .gallery {
    display: grid;
    gap: 0.5rem;
    margin: 1.5rem 0;
  }
  .gallery[data-cols='2'] { grid-template-columns: repeat(2, 1fr); }
  .gallery[data-cols='3'] { grid-template-columns: repeat(3, 1fr); }
  .gallery[data-cols='4'] { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 640px) {
    .gallery[data-cols='3'],
    .gallery[data-cols='4'] {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .gallery-item {
    border: 0;
    padding: 0;
    background: transparent;
    cursor: zoom-in;
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 1;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }
  .gallery-item:hover img {
    transform: scale(1.04);
  }

  .gallery-lightbox {
    border: 0;
    padding: 0;
    background: rgba(0, 0, 0, 0.92);
    color: white;
    max-width: min(95vw, 1400px);
    max-height: 95vh;
  }
  .gallery-lightbox::backdrop {
    background: rgba(0, 0, 0, 0.92);
  }
  .gallery-lightbox figure {
    margin: 0;
    padding: 1rem;
  }
  .gallery-lightbox img {
    max-width: 100%;
    max-height: 80vh;
    height: auto;
    display: block;
    margin: 0 auto;
  }
  .gallery-lightbox figcaption {
    text-align: center;
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.85);
  }
  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: 0;
    color: white;
    font-size: 3rem;
    cursor: pointer;
    padding: 0 1rem;
    line-height: 1;
  }
  .lightbox-close { top: 1rem; right: 1rem; transform: none; font-size: 2.5rem; }
  .lightbox-prev { left: 0.5rem; }
  .lightbox-next { right: 0.5rem; }
</style>
