---
interface Props {
  caption?: string;
  source?: string;
  sourceUrl?: string;
}

const { caption, source, sourceUrl } = Astro.props;
---
<figure class="figure">
  <slot />
  {(caption || source) && (
    <figcaption>
      {caption}
      {source && (
        <span class="source">
          {' '}—{' '}
          {sourceUrl ? <a href={sourceUrl} rel="noopener noreferrer">{source}</a> : source}
        </span>
      )}
    </figcaption>
  )}
</figure>

<style>
  .figure {
    margin: 1.5rem 0;
  }
  figcaption {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
    font-style: italic;
  }
  .source {
    font-style: normal;
    font-size: 0.75rem;
  }
</style>
