---
interface Props {
  level: 1 | 2 | 3 | 4 | 5;
  max?: number;
  label?: boolean;
}

const { level, max = 5, label = true } = Astro.props;
const levels = ['', 'Muy fácil', 'Fácil', 'Medio', 'Difícil', 'Experto'];
---
<span class="difficulty" aria-label={`Dificultad: ${level} de ${max}`}>
  <span class="stars" aria-hidden="true">
    {Array.from({ length: max }).map((_, i) => (
      <span class:list={['star', { filled: i < level }]}>★</span>
    ))}
  </span>
  {label && <span class="diff-label">{levels[level]}</span>}
</span>

<style>
  .difficulty {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
  }
  .stars {
    display: inline-flex;
    gap: 0.1rem;
    color: var(--color-border);
  }
  .star.filled { color: var(--color-accent-yellow); }
  .diff-label {
    color: var(--color-muted);
    font-weight: 600;
  }
</style>
