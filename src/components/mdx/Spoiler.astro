---
interface Props {
  summary: string;
}

const { summary } = Astro.props;
---
<details class="spoiler not-prose">
  <summary>{summary}</summary>
  <div class="spoiler-body">
    <slot />
  </div>
</details>

<style>
  .spoiler {
    margin: 1.25rem 0;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg-elev);
    overflow: hidden;
  }
  .spoiler > summary {
    padding: 0.75rem 1rem;
    cursor: pointer;
    font-weight: 600;
    color: var(--color-fg);
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }
  .spoiler > summary::-webkit-details-marker {
    display: none;
  }
  .spoiler > summary::before {
    content: '▶';
    color: var(--color-accent);
    font-size: 0.7rem;
    transition: transform 0.15s ease;
  }
  .spoiler[open] > summary::before {
    transform: rotate(90deg);
  }
  .spoiler > summary:hover {
    color: var(--color-accent);
  }
  .spoiler > summary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
  .spoiler-body {
    padding: 0 1rem 1rem;
    color: var(--color-muted);
  }
</style>
