---
import { Image as AstroImage } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
  fullBleed?: boolean;
  loading?: 'lazy' | 'eager';
}

const { src, alt, caption, width = 1280, height: heightProp, fullBleed = false, loading = 'lazy' } = Astro.props;
const height = heightProp ?? Math.round(width * (9 / 16));

const isRemote = /^https?:\/\//.test(src);
const figureClass = fullBleed ? 'media-full-bleed' : 'media-figure';
---
<figure class={figureClass}>
  {isRemote ? (
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
    />
  ) : (
    <AstroImage
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      format="webp"
    />
  )}
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .media-figure,
  .media-full-bleed {
    margin: 1.5rem 0;
  }
  .media-figure img,
  .media-figure :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .media-full-bleed {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
  .media-full-bleed img,
  .media-full-bleed :global(img) {
    width: 100%;
    height: auto;
    border-radius: 0;
  }
  figcaption {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-muted);
    font-style: italic;
  }
</style>
