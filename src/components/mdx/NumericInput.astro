---
interface Props {
  question: string;
  answer: number;
  tolerance?: number;
  unit?: string;
  hint?: string;
  explain?: string;
}

const { question, answer, tolerance = 0.001, unit, hint, explain } = Astro.props;
const id = `ni-${Math.random().toString(36).slice(2, 9)}`;
---
<div
  class="ni not-prose"
  data-ni={id}
  data-answer={answer}
  data-tolerance={tolerance}
  data-explain={explain ?? ''}
>
  <p class="ni-q"><span class="ni-icon" aria-hidden="true">🧮</span> {question}</p>
  <div class="ni-input-row">
    <input
      type="number"
      step="any"
      class="ni-input"
      placeholder="?"
      data-ni-input
      aria-label="Tu respuesta"
    />
    {unit && <span class="ni-unit">{unit}</span>}
    <button type="button" class="ni-check" data-ni-check>Verificar</button>
  </div>
  <div class="ni-feedback" data-ni-feedback hidden></div>
  {hint && <details class="ni-hint"><summary>💡 Pista</summary><p>{hint}</p></details>}
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-ni]').forEach((root) => {
    const answer = Number(root.dataset.answer);
    const tolerance = Number(root.dataset.tolerance);
    const explain = root.dataset.explain;
    const input = root.querySelector<HTMLInputElement>('[data-ni-input]');
    const check = root.querySelector<HTMLButtonElement>('[data-ni-check]');
    const feedback = root.querySelector<HTMLElement>('[data-ni-feedback]');

    const verify = () => {
      if (!input || !feedback) return;
      const value = Number(input.value);
      if (Number.isNaN(value)) {
        feedback.hidden = false;
        feedback.className = 'ni-feedback fb-incorrect';
        feedback.textContent = '✗ Ingresá un número.';
        return;
      }
      const correct = Math.abs(value - answer) <= tolerance;
      feedback.hidden = false;
      feedback.className = `ni-feedback ${correct ? 'fb-correct' : 'fb-incorrect'}`;
      feedback.textContent = correct
        ? `✓ ¡Correcto! ${explain ?? ''} (+5 XP)`
        : `✗ Probá de nuevo. ${explain ?? ''}`;
      if (correct) {
        const id = root.dataset.ni ?? '';
        import('../../lib/xp').then((m) => m.awardXP(5, `ni:${id}`));
      }
    };

    check?.addEventListener('click', verify);
    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        verify();
      }
    });
  });
</script>

<style>
  .ni {
    margin: 1.5rem 0;
    padding: 1.25rem;
    border: 2px solid var(--color-m);
    border-radius: 12px;
    background: color-mix(in oklch, var(--color-m-soft) 25%, var(--color-bg));
  }
  .ni-q {
    margin: 0 0 1rem;
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--color-fg);
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .ni-icon {
    font-size: 1.4rem;
  }
  .ni-input-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .ni-input {
    flex: 1;
    min-width: 0;
    max-width: 12rem;
    padding: 0.6rem 0.85rem;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-bg);
    color: var(--color-fg);
    font: inherit;
    font-size: var(--text-lg);
    font-family: var(--font-mono);
    text-align: right;
  }
  .ni-input:focus {
    outline: none;
    border-color: var(--color-m);
  }
  .ni-unit {
    font-family: var(--font-mono);
    color: var(--color-muted);
    font-size: 0.95rem;
  }
  .ni-check {
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--color-m), var(--color-accent-2));
    color: white;
    border: 0;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .ni-check:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 14px color-mix(in oklch, var(--color-m) 35%, transparent);
  }
  .ni-feedback {
    margin-top: 0.85rem;
    padding: 0.7rem 1rem;
    border-radius: 6px;
    font-weight: 600;
  }
  .fb-correct {
    background: color-mix(in oklch, oklch(0.55 0.18 145) 18%, var(--color-bg));
    color: oklch(0.45 0.18 145);
  }
  .fb-incorrect {
    background: color-mix(in oklch, oklch(0.6 0.18 25) 18%, var(--color-bg));
    color: oklch(0.5 0.18 25);
  }
  .ni-hint {
    margin-top: 0.85rem;
    font-size: 0.9rem;
  }
  .ni-hint summary {
    cursor: pointer;
    color: var(--color-muted);
    font-weight: 600;
  }
  .ni-hint p {
    margin: 0.4rem 0 0;
    color: var(--color-muted);
  }
</style>
