---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Disclosure — hidx" description="Affiliate and sponsorship disclosure.">
  <h1 class="text-3xl font-bold mb-6">Disclosure</h1>
  <div class="prose prose-invert max-w-none">
    <h2>Affiliate links</h2>
    <p>
      Some posts contain affiliate links — clearly marked with <code>[aff]</code> next to the link.
      If you click and make a purchase, hidx may earn a commission at no extra cost to you.
    </p>
    <p>
      We only recommend tools and services we use ourselves or believe deliver real value to readers.
    </p>
    <h2>Sponsorships</h2>
    <p>
      Sponsored posts (when present) are labeled at the top of the article with a "Sponsored" tag
      and the sponsor's name. Editorial control of the post content remains with hidx.
    </p>
    <h2>FTC compliance</h2>
    <p>
      This disclosure complies with the U.S. Federal Trade Commission's
      <a href="https://www.ftc.gov/news-events/topics/truth-advertising/endorsements" target="_blank" rel="noopener noreferrer">
        Endorsement Guidelines
      </a>
      and EU consumer protection regulations.
    </p>
  </div>
</BaseLayout>
