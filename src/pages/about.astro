---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About — hidx" description="About hidx and the author.">
  <h1 class="text-3xl font-bold mb-6">About</h1>
  <div class="prose prose-invert max-w-none">
    <p>
      hidx is a long-form publication where I document how I solve real problems with code,
      infrastructure, and tools. Each post is opinionated, reproducible, and end-to-end.
    </p>
    <p>
      I'm Felipe Talavera, senior software architect.
      Background: Clean / Hexagonal / Screaming Architecture, testing, atomic design.
    </p>
  </div>
</BaseLayout>
