    <h1 class="text-6xl font-bold">404</h1>
    <p class="text-xl text-(--color-muted)">This page doesn't exist (or doesn't exist yet).</p>
    <p>
      <a href="/">Back to home</a>
    </p>
  </section>
</BaseLayout>
