---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AgeBadge from '../../components/mdx/AgeBadge.astro';
import STEAMBadge from '../../components/mdx/STEAMBadge.astro';
import DifficultyStars from '../../components/mdx/DifficultyStars.astro';
import DurationBadge from '../../components/mdx/DurationBadge.astro';

const TRACK_SLUG = 'octavo-basico-chile';
const track = await getEntry('series', TRACK_SLUG);
if (!track) throw new Error(`Track ${TRACK_SLUG} not found`);

const lessons = await Promise.all(
  track.data.lessons.map(async (slug) => {
    const lesson = await getEntry('posts', slug);
    return lesson ? { id: slug, ...lesson.data } : null;
  }),
);
const validLessons = lessons.filter((l): l is NonNullable<typeof l> => l !== null);
const totalMinutes = validLessons.reduce((sum, l) => sum + (l.durationMinutes ?? 0), 0);
---
<BaseLayout
  title="Roadmap 8° Básico Chile — YachayTree"
  description="Roadmap visual de actividades STEAM hands-on alineadas al currículum nacional MINEDUC para 8° básico Chile."
>
  <article class="rm-page">
    <header class="rm-hero">
      <p class="rm-tag">📍 ROADMAP CURRICULAR</p>
      <h1>{track.data.title}</h1>
      <p class="lede">{track.data.description}</p>
      <div class="rm-badges">
        <AgeBadge min={track.data.ageMin} max={track.data.ageMax} />
        <STEAMBadge categories={track.data.steamCategories} />
        <span class="meta">📚 {validLessons.length} lecciones</span>
        <span class="meta">⏱️ ~{Math.round(totalMinutes / 60 * 10) / 10}h totales</span>
      </div>
    </header>

    <hr class="grad-rule" />

    <ol class="lesson-flow">
      {validLessons.map((l, i) => (
        <li class="flow-node">
          <div class="flow-num" aria-hidden="true">{i + 1}</div>
          <a href={`/rutas/${TRACK_SLUG}/${l.id}`} class="flow-card">
            <h3>{l.title}</h3>
            <p>{l.description}</p>
            <div class="flow-meta">
              <AgeBadge min={l.ageMin ?? 11} max={l.ageMax ?? 14} />
              {l.steamCategories && l.steamCategories.length > 0 && (
                <STEAMBadge categories={l.steamCategories} size="sm" />
              )}
              <DifficultyStars level={(l.difficulty ?? 2) as 1 | 2 | 3 | 4 | 5} label={false} />
              <DurationBadge minutes={l.durationMinutes ?? 30} />
            </div>
          </a>
          {i < validLessons.length - 1 && <div class="flow-connector" aria-hidden="true" />}
        </li>
      ))}
    </ol>

    <section class="rm-cta">
      <h2>Empezá ahora</h2>
      <p>Cada lección es independiente. Empezá por la que más te interese o seguí el orden curricular.</p>
      <a href={`/rutas/${TRACK_SLUG}/${validLessons[0].id}`} class="cta primary">
        Ver primera lección →
      </a>
    </section>
  </article>
</BaseLayout>

<style>
  .rm-page {
    max-width: 50rem;
  }
  .rm-hero {
    text-align: center;
    padding: 1rem 0 1.5rem;
  }
  .rm-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin: 0 0 0.6rem;
  }
  .rm-hero h1 {
    font-size: var(--text-3xl);
    font-weight: 800;
    margin: 0 0 0.6rem;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-s), var(--color-e), var(--color-m));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lede {
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin: 0 auto 1rem;
    line-height: 1.5;
    max-width: 50ch;
  }
  .rm-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    justify-content: center;
  }
  .rm-badges .meta {
    font-size: 0.85rem;
    color: var(--color-muted);
    font-weight: 600;
  }
  .grad-rule {
    border: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-accent), var(--color-accent-2), transparent);
    margin: 2rem 0;
  }

  .lesson-flow {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .flow-node {
    display: grid;
    place-items: center;
    width: 100%;
    max-width: 36rem;
    position: relative;
  }
  .flow-num {
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 900;
    font-size: 1.1rem;
    z-index: 2;
  }
  .flow-card {
    margin-top: 0.5rem;
    width: 100%;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    background: var(--color-bg-elev);
    border: 2px solid color-mix(in oklch, var(--color-accent) 25%, var(--color-border));
    text-decoration: none;
    color: var(--color-fg);
    transition: transform 0.18s ease, border-color 0.18s ease;
    display: block;
  }
  .flow-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    color: var(--color-fg);
  }
  .flow-card h3 {
    margin: 0 0 0.4rem;
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-accent);
  }
  .flow-card p {
    margin: 0 0 0.75rem;
    color: var(--color-muted);
    line-height: 1.5;
    font-size: 0.95rem;
  }
  .flow-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
  }
  .flow-connector {
    width: 3px;
    height: 1.5rem;
    background: linear-gradient(180deg, var(--color-accent), var(--color-accent-2));
    opacity: 0.5;
    margin: 0.5rem 0;
  }

  .rm-cta {
    margin-top: 3rem;
    padding: 2rem;
    text-align: center;
    border-top: 1px solid var(--color-border);
  }
  .rm-cta h2 {
    font-size: var(--text-xl);
    margin: 0 0 0.5rem;
    font-weight: 700;
  }
  .rm-cta p {
    color: var(--color-muted);
    margin: 0 0 1rem;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.85rem 1.5rem;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 700;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .cta.primary {
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2));
    color: white;
  }
  .cta.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px color-mix(in oklch, var(--color-accent-2) 35%, transparent);
    color: white;
  }
</style>
