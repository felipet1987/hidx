---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy — hidx" description="Privacy policy for hidx.">
  <h1 class="text-3xl font-bold mb-6">Privacy</h1>
  <div class="prose prose-invert max-w-none">
    <h2>What we collect</h2>
    <p>
      <strong>Analytics</strong>: Cloudflare Web Analytics. No cookies, no fingerprinting,
      no cross-site tracking. Aggregated, anonymized stats only.
    </p>
    <p>
      <strong>Newsletter</strong>: if you subscribe, your email is stored by Beehiiv (our newsletter provider).
      You can unsubscribe at any time using the link in every email.
    </p>
    <h2>What we do not collect</h2>
    <ul>
      <li>No third-party advertising cookies.</li>
      <li>No session replay tools.</li>
      <li>No personal identifiers beyond what you voluntarily submit.</li>
    </ul>
    <h2>Hosting</h2>
    <p>
      Static content is served by Cloudflare Pages. Server logs may be retained briefly
      by Cloudflare for security and abuse prevention.
    </p>
    <h2>Contact</h2>
    <p>
      Questions? Open an issue at
      <a href="https://github.com/felipet1987/hidx/issues" target="_blank" rel="noopener noreferrer">github.com/felipet1987/hidx</a>.
    </p>
  </div>
</BaseLayout>
