---
import BaseLayout from '../layouts/BaseLayout.astro';
const updated = '2026-04-28';
---
<BaseLayout title="Now — hidx" description="What I'm focused on right now.">
  <h1 class="text-3xl font-bold mb-2">Now</h1>
  <p class="text-sm text-(--color-muted) mb-6">Updated {updated}</p>
  <div class="prose prose-invert max-w-none">
    <ul>
      <li>Building hidx — the platform you're reading.</li>
      <li>Drafting the first 5 pillar posts.</li>
    </ul>
    <p class="text-sm text-(--color-muted)">
      Inspired by <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">/now pages</a>.
    </p>
  </div>
</BaseLayout>
