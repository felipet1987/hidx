---
import BaseLayout from '../layouts/BaseLayout.astro';
const updated = '2026-04-28';
---
<BaseLayout title="Ahora — hidx" description="En lo que estoy trabajando ahora mismo.">
  <h1 class="text-3xl font-bold mb-2">Ahora</h1>
  <p class="text-sm text-(--color-muted) mb-6">Actualizado {updated}</p>
  <div class="prose dark:prose-invert max-w-none">
    <ul>
      <li>Construyendo hidx — la plataforma que estás leyendo.</li>
      <li>Escribiendo los primeros 5 artículos pilares.</li>
    </ul>
    <p class="text-sm text-(--color-muted)">
      Inspirado por <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">/now pages</a>.
    </p>
  </div>
</BaseLayout>
