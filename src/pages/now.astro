---
import BaseLayout from '../layouts/BaseLayout.astro';
const updated = '2026-04-29';
---
<BaseLayout title="Ahora — YachayTree" description="En lo que estamos trabajando ahora mismo.">
  <h1 class="text-3xl font-bold mb-2">Ahora</h1>
  <p class="text-sm text-(--color-muted) mb-6">Actualizado {updated}</p>
  <div class="prose dark:prose-invert max-w-none">
    <p><strong>Estado MVP S1:</strong></p>
    <ul>
      <li>Construyendo las primeras 10 lecciones STEAM hands-on (Engineering + Arte) para chicos 8-12.</li>
      <li>3 rutas curadas: "Inventos con cartón", "Arte con luz", "Mecánica para chicos".</li>
      <li>Materiales todos &lt;$5 USD por proyecto.</li>
      <li>Sin ads, sin tracking, sin signup. localStorage para "marcar completado".</li>
    </ul>
    <p class="text-sm text-(--color-muted)">
      Inspirado por <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer">/now pages</a>.
    </p>
  </div>
</BaseLayout>
